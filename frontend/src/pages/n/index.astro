---
import NoteViewer from '@/components/NoteViewer.tsx'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
---

<Layout class="max-w-5xl">
  <PageHead slot="head" title="note" />

  <NoteViewer client:only="react">
    <div
      slot="fallback"
      class="text-muted-foreground flex h-[70vh] items-center justify-center text-sm"
    >
      Loading note&hellip;
    </div>
  </NoteViewer>
</Layout>
