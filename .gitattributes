# Normalize line endings: store as LF in the repo, check out native locally.
* text=auto

# Unix shell scripts and container files must stay LF (they run on Linux).
mvnw text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Windows scripts stay CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pptx binary
